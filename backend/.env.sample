# ==== APP ===========================================================
APP_NAME="Samba Simulator API"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ==== SECURITY ======================================================
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ==== DATABASE (compose) ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=samba_simulator

# Nome do serviço do Postgres no docker-compose (hostname visível para a API)
DB_HOST=samba_pg
DB_PORT=5432

# URL usada pela API (dentro do container)
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# (Dica local - cliente psql/GUI no HOST) postgresql://postgres:postgres@localhost:5433/samba_simulator

# ==== CORS ==========================================================
BACKEND_CORS_ORIGINS=http://localhost:3000

# ==== STORAGE/FILES ================================================
STORAGE_DIR=/app/storage

# ==== LOGGING =======================================================
LOG_LEVEL=INFO